{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "codex_peer_review_schema.json",
  "title": "Codex Peer Review Response Schema",
  "description": "피어 리뷰 에이전트(arch-critic, code-auditor, codex-challenger)의 구조화된 응답 형식. base_issue_schema 참조.",
  "type": "object",
  "required": ["agent", "agent_status", "status_reason", "issues", "challenges", "strengths", "overall_assessment"],
  "additionalProperties": false,
  "properties": {
    "agent": {
      "type": "string",
      "description": "에이전트 ID (예: arch-critic, code-auditor, codex-challenger)"
    },
    "agent_status": {
      "type": "string",
      "enum": ["ok", "partial", "failed"],
      "description": "에이전트 실행 상태: ok(정상), partial(부분 실패), failed(전체 실패)"
    },
    "status_reason": {
      "type": "string",
      "description": "상태 설명 (예: '정상', 'pre-cache 부분 실패, import_graph 누락')"
    },
    "issues": {
      "type": "array",
      "description": "발견된 이슈 목록 (최대 10개)",
      "maxItems": 10,
      "items": {
        "type": "object",
        "required": ["id", "perspective", "file", "line_range", "severity", "confidence", "origin", "description", "impact", "suggestion", "alternatives", "recommended", "evidence_trace"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "description": "이슈 고유 식별자 (예: ARCH-001, CODE-003)"
          },
          "perspective": {
            "$comment": "→ codex_base_issue_schema.json#/$defs/unified_category 의 서브셋 (peer-review 관점용)",
            "type": "string",
            "enum": [
              "architecture",
              "extensibility",
              "over_engineering",
              "decomposition",
              "modern_api",
              "dependency",
              "performance",
              "refactoring_completeness",
              "concurrency_safety",
              "requirements_alignment"
            ],
            "description": "리뷰 관점 (unified_category의 peer-review 서브셋)"
          },
          "file": {
            "type": "string",
            "description": "이슈가 발견된 파일 경로"
          },
          "line_range": {
            "type": "string",
            "description": "라인 범위 (예: '45-60' 또는 '72')"
          },
          "severity": {
            "$comment": "→ codex_base_issue_schema.json#/$defs/severity",
            "type": "string",
            "enum": ["critical", "major", "minor", "suggestion"],
            "description": "심각도: critical(즉시 수정), major(수정 권장), minor(선택적), suggestion(제안)"
          },
          "confidence": {
            "$comment": "→ codex_base_issue_schema.json#/$defs/confidence",
            "type": "integer",
            "minimum": 0,
            "maximum": 100,
            "description": "이슈 신뢰도 0-100 (높을수록 확실)"
          },
          "origin": {
            "type": "string",
            "enum": ["regression", "pre-existing", "improvement"],
            "description": "이슈 출처: regression(PR이 만든 새 문제), pre-existing(원본에도 있던 동작), improvement(개선 여지)"
          },
          "description": {
            "type": "string",
            "description": "문제 설명 (400자 이내). 왜 문제인지(WHY) 포함 필수. 단순 '누락'/'중복' 서술이 아닌, 기존 동작과의 차이 + 발생 조건 + 결과를 포함."
          },
          "impact": {
            "type": ["string", "null"],
            "description": "실제 사용자/시스템에 미치는 영향 (major 이상 필수, minor 이하 null). 예: '분석 데이터 단절로 타임머신 사용량 지표 추적 불가'"
          },
          "suggestion": {
            "type": "string",
            "description": "수정 제안 (300자 이내)"
          },
          "alternatives": {
            "$comment": "→ codex_base_issue_schema.json#/$defs/alternatives",
            "type": ["array", "null"],
            "description": "대안 비교 (major 이상, minor 이하는 null)",
            "items": {
              "type": "object",
              "required": ["label", "description", "pros", "cons"],
              "additionalProperties": false,
              "properties": {
                "label": { "type": "string", "description": "대안 명칭 (예: A: 현재 구현)" },
                "description": { "type": "string", "description": "접근 방식 설명" },
                "pros": { "type": "array", "items": { "type": "string" } },
                "cons": { "type": "array", "items": { "type": "string" } }
              }
            }
          },
          "recommended": {
            "type": ["string", "null"],
            "description": "추천 대안 label (minor 이하는 null)"
          },
          "evidence_trace": {
            "type": ["string", "null"],
            "description": "코드 추적 증거 (major 이상 필수, minor 이하 null). 실제 코드베이스의 코드 경로를 step-by-step으로 보여주어 문제를 시각적으로 증명한다. 각 step에 파일:라인 출처와 인라인 주석으로 데이터 타입/값 변화를 표시. 텍스트 설명 대신 코드가 스스로 증명하도록 작성."
          }
        }
      }
    },
    "challenges": {
      "type": "array",
      "description": "Devil's Advocate 결과 (DA 모드에서만 사용)",
      "items": {
        "type": "object",
        "required": ["target_issue_id", "action", "reason"],
        "additionalProperties": false,
        "properties": {
          "target_issue_id": {
            "type": "string",
            "description": "대상 이슈 ID (예: ARCH-001)"
          },
          "action": {
            "type": "string",
            "enum": ["agree", "challenge", "supplement", "reverse"],
            "description": "판정: agree(동의), challenge(반박-confidence 20% 감소), supplement(보완), reverse(역전-원래 이슈 제외 후 새 이슈 생성)"
          },
          "reason": {
            "type": "string",
            "description": "판정 근거"
          }
        }
      }
    },
    "strengths": {
      "type": "array",
      "description": "코드의 강점 (최대 3개)",
      "items": {
        "type": "string"
      }
    },
    "overall_assessment": {
      "type": "string",
      "enum": ["excellent", "good", "needs_improvement", "major_concerns"],
      "description": "전체 평가: excellent(우수), good(양호), needs_improvement(개선 필요), major_concerns(심각한 문제)"
    }
  }
}
